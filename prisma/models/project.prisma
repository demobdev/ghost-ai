enum ProjectStatus {
  DRAFT
  ARCHIVED
}

model Project {
  id             String        @id @default(cuid())
  ownerId        String
  name           String
  description    String?
  status         ProjectStatus @default(DRAFT)
  githubRepoUrl  String?
  canvasBlobUrl  String?
  createdAt      DateTime      @default(now())
  updatedAt      DateTime      @updatedAt

  collaborators ProjectCollaborator[]
  specs         ProjectSpec[]
  reviews       ProjectReview[]

  @@index([ownerId])
  @@index([createdAt])
}

model TaskRun {
  id        String   @id @default(cuid())
  runId     String   @unique
  projectId String
  userId    String
  createdAt DateTime @default(now())

  @@index([runId])
  @@index([userId, projectId])
}

model ProjectSpec {
  id          String   @id @default(cuid())
  projectId   String
  filePath    String
  snapshotUrl String?
  createdAt   DateTime @default(now())

  project Project @relation(fields: [projectId], references: [id], onDelete: Cascade)

  @@index([projectId])
}

model ProjectCollaborator {
  id        String   @id @default(cuid())
  projectId String
  email     String
  createdAt DateTime @default(now())

  project Project @relation(fields: [projectId], references: [id], onDelete: Cascade)

  @@unique([projectId, email])
  @@index([email])
  @@index([projectId, createdAt])
}

model ProjectReview {
  id          String   @id @default(cuid())
  projectId   String
  score       Int
  summary     String
  findings    Json
  createdAt   DateTime @default(now())

  project Project @relation(fields: [projectId], references: [id], onDelete: Cascade)

  @@index([projectId])
  @@index([projectId, createdAt])
}
